# ════════════════════════════════════════════════════════
#  Monetixra — Environment Variables Template
#  IMPORTANT: 
#  1. Copy this file to .env
#  2. Fill in your actual values
#  3. NEVER commit .env to git (it's in .gitignore for security)
# ════════════════════════════════════════════════════════

# ── Server Configuration ──────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# For production on Render:
# BASE_URL=https://your-app.onrender.com
# NODE_ENV=production

# ── Database: Supabase ────────────────────────────────
# Get from: https://supabase.com/dashboard
# 1. Create a new project
# 2. Go to Settings → API to find your credentials
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Google Cloud APIs ────────────────────────────────
# Get from: https://console.cloud.google.com/
# Enable: Google Vision API, Google Search Console, etc.
GOOGLE_API_KEY=
GOOGLE_VISION_KEY=
GOOGLE_ACCESS_KEY=

# ── AI: OpenAI ───────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
# Model used: gpt-4o-mini (cost-effective)
OPENAI_API_KEY=sk-

# ── AI: DeepSeek ─────────────────────────────────────
# Get from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-

# ── WebRTC: TURN Servers ─────────────────────────────
# For peer-to-peer video calls via Metered.ca
# Free tier available, sign up at: https://metered.ca
METERED_API_KEY=

# ── Payment: Stripe ──────────────────────────────────
# Get from: https://dashboard.stripe.com/
# For webhook signature verification
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_test_

# ── Payment: bKash ───────────────────────────────────
# Bangladesh payment gateway
# Register at: https://developer.bkash.com/
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=

# ── Payment: Nagad ───────────────────────────────────
# Bangladesh payment gateway
# Register at: https://nagad.com.bd/merchant
NAGAD_MERCHANT_ID=
NAGAD_PUBLIC_KEY=

# ── Web Push Notifications ───────────────────────────
# Generate keys using: npm run vapid
# These enable PWA push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:your-email@example.com

# ── EmailJS (Email Notifications) ────────────────────
# Setup at: https://www.emailjs.com/
# Used for OTP emails, notifications, etc.
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=

# ── Optional: Monitoring ─────────────────────────────
# For error tracking and performance monitoring
SENTRY_DSN=
